# bleverse.com runtime config
NODE_ENV="production"
PORT="3000"
APP_NAME="bleverse-web"
LOG_LEVEL="info"
# Optional: bind address (e.g. 0.0.0.0 for all interfaces in production)
# BIND_HOST=0.0.0.0

VITE_BASE_URL="http://localhost:3000"

DATABASE_URL="postgresql://bleverse_dev:change_me@127.0.0.1:5432/bleverse_dev"
# Dev DB contract: bleverse_dev on local PostgreSQL.
# Prod DB contract: bleverse_prod via /home/deploy/.config/bleverse/{bleverse-web,bleverse-api}.env

# bun auth:secret
BETTER_AUTH_SECRET=""

POLAR_ACCESS_TOKEN=""
POLAR_SUCCESS_URL="http://localhost:3000/app"
POLAR_MODE="sandbox"

# OAuth2 providers, optional, update as needed
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NOTE:
# In OAuth2 apps, set callback/redirect URIs to `http://localhost:3000/api/auth/callback/<provider>`
# e.g. http://localhost:3000/api/auth/callback/github

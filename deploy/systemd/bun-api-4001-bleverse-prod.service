[Unit]
Description=Bun API bleverse.com PROD (:4001) [deploy user]
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=/home/deploy/prod/reliverse/bleverse/current/apps/api
Environment=PORT=4001
Environment=NODE_ENV=production
ExecStart=/usr/local/bin/bun run start
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
